<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Level Up! 💕</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Dancing+Script:wght@600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #020617; overflow: hidden; }
        .font-script { font-family: 'Dancing Script', cursive; }
        
        /* Floating Hearts Background */
        .heart {
            position: absolute;
            color: rgba(244, 114, 182, 0.4);
            animation: floatUp 6s linear infinite;
            z-index: 0;
        }
        @keyframes floatUp {
            0% { transform: translateY(100vh) scale(0); opacity: 0; }
            50% { opacity: 0.8; }
            100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
        }

        /* Sparkle Particles */
        .sparkle {
            position: absolute;
            width: 4px; height: 4px;
            background: white;
            border-radius: 50%;
            animation: drift 10s linear infinite;
        }
        @keyframes drift {
            from { transform: translate(0, 0); }
            to { transform: translate(100px, 100px); opacity: 0; }
        }

        /* Cake Animations */
        .cake-rise { animation: rise 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        @keyframes rise {
            from { transform: translateY(100px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .flicker {
            animation: flameFlicker 0.1s infinite alternate;
        }
        @keyframes flameFlicker {
            from { transform: scale(1) rotate(-2deg); opacity: 0.8; }
            to { transform: scale(1.1) rotate(2deg); opacity: 1; }
        }

        .hidden-card { display: none; }
    </style>
</head>
<body class="text-white flex items-center justify-center min-h-screen relative">

    <!-- Audio Element -->
    <audio id="bgMusic" loop>
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
        <!-- Note: Replace the URL above with your "Hopelessly Devoted to You" mp3 link -->
    </audio>

    <!-- Background Elements -->
    <div id="hearts-container"></div>
    <div class="fixed inset-0 bg-gradient-to-b from-transparent via-pink-950/10 to-purple-950/20 pointer-events-none"></div>

    <!-- Top Controls -->
    <div class="absolute top-6 right-6 z-50 flex gap-4">
        <button onclick="toggleMusic()" class="w-12 h-12 bg-white/10 backdrop-blur-md rounded-full border border-pink-500/30 flex items-center justify-center hover:bg-pink-500/20 transition-all">
            <span id="musicIcon">🎵</span>
        </button>
    </div>

    <!-- Main Content -->
    <div class="relative z-10 w-full max-w-lg px-6 text-center">
        
        <!-- Step 1: Glowing Title -->
        <div id="card-0" class="card active">
            <h1 class="text-5xl md:text-6xl font-black mb-6 animate-pulse bg-clip-text text-transparent bg-gradient-to-r from-pink-400 to-purple-500">
                HAPPY <br> LEVEL UP!
            </h1>
            <p class="text-pink-200/70 mb-8">Click below to start our journey...</p>
            <button onclick="nextCard(0)" class="bg-pink-600 hover:bg-pink-500 px-8 py-3 rounded-full font-bold shadow-lg shadow-pink-500/40 transition-transform active:scale-95">Open ❤️</button>
        </div>

        <!-- Step 2: Message 1 -->
        <div id="card-1" class="hidden-card">
            <div class="bg-white/5 backdrop-blur-lg p-8 rounded-3xl border border-white/10 shadow-2xl">
                <p class="text-xl leading-relaxed font-medium">
                    Happy level up to the man who makes life way more interesting. <br><br>
                    im so proud of who u r and honestly so happy i have u by my side.
                </p>
                <div class="mt-6 flex justify-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-pink-500"></div>
                    <div class="w-2 h-2 rounded-full bg-white/20"></div>
                    <div class="w-2 h-2 rounded-full bg-white/20"></div>
                </div>
                <button onclick="nextCard(1)" class="mt-8 text-pink-400 font-bold uppercase tracking-widest text-sm hover:text-pink-300">Continue →</button>
            </div>
        </div>

        <!-- Step 3: Message 2 -->
        <div id="card-2" class="hidden-card">
            <div class="bg-white/5 backdrop-blur-lg p-8 rounded-3xl border border-white/10 shadow-2xl">
                <p class="text-xl leading-relaxed font-medium">
                    U r literally my favorite person to talk to and my safest place to be. <br><br>
                    okey im sorry i know sometimes i disappear, but that doesn't mean i don't care i promise.
                </p>
                <div class="mt-6 flex justify-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-pink-500"></div>
                    <div class="w-2 h-2 rounded-full bg-pink-500"></div>
                    <div class="w-2 h-2 rounded-full bg-white/20"></div>
                </div>
                <button onclick="nextCard(2)" class="mt-8 text-pink-400 font-bold uppercase tracking-widest text-sm hover:text-pink-300">Continue →</button>
            </div>
        </div>

        <!-- Step 4: Message 3 -->
        <div id="card-3" class="hidden-card">
            <div class="bg-white/5 backdrop-blur-lg p-8 rounded-3xl border border-white/10 shadow-2xl">
                <p class="text-lg leading-relaxed">
                    and even though ur joking makes me annoyed and jealous sometimes so shut up haha, i still wouldn't trade u for anyone else, im sorry i can't give u an expensive gift...
                </p>
                <div class="mt-6 flex justify-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-pink-500"></div>
                    <div class="w-2 h-2 rounded-full bg-pink-500"></div>
                    <div class="w-2 h-2 rounded-full bg-pink-500"></div>
                </div>
                <button onclick="showCake()" class="mt-8 bg-gradient-to-r from-pink-500 to-purple-600 px-6 py-2 rounded-full text-white font-bold">See Surprise 🎂</button>
            </div>
        </div>

        <!-- Final Step: The Cake -->
        <div id="cake-screen" class="hidden-card">
            <h2 class="text-3xl font-script text-pink-300 mb-8">Happy level upp my mannn! i hope we are together always</h2>
            
            <div class="cake-rise relative flex flex-col items-center">
                <!-- 5 Candles -->
                <div class="flex gap-4 mb-[-8px] z-30">
                    <div class="candle w-2 h-10 bg-blue-200 rounded-t-sm relative"><div class="flicker absolute -top-4 left-1/2 -translate-x-1/2 w-3 h-5 bg-orange-400 rounded-full blur-[2px]"></div></div>
                    <div class="candle w-2 h-10 bg-pink-200 rounded-t-sm relative"><div class="flicker absolute -top-4 left-1/2 -translate-x-1/2 w-3 h-5 bg-orange-400 rounded-full blur-[2px]"></div></div>
                    <div class="candle w-2 h-10 bg-yellow-200 rounded-t-sm relative"><div class="flicker absolute -top-4 left-1/2 -translate-x-1/2 w-3 h-5 bg-orange-400 rounded-full blur-[2px]"></div></div>
                    <div class="candle w-2 h-10 bg-green-200 rounded-t-sm relative"><div class="flicker absolute -top-4 left-1/2 -translate-x-1/2 w-3 h-5 bg-orange-400 rounded-full blur-[2px]"></div></div>
                    <div class="candle w-2 h-10 bg-purple-200 rounded-t-sm relative"><div class="flicker absolute -top-4 left-1/2 -translate-x-1/2 w-3 h-5 bg-orange-400 rounded-full blur-[2px]"></div></div>
                </div>

                <!-- Tier 1 (Small) -->
                <div class="w-32 h-12 bg-pink-300 rounded-t-lg border-b-4 border-pink-400 z-20 relative">
                    <div class="absolute inset-x-0 top-0 h-4 bg-white/40 rounded-t-lg"></div>
                </div>
                <!-- Tier 2 (Medium) -->
                <div class="w-48 h-16 bg-pink-400 border-b-4 border-pink-500 z-10 relative">
                    <div class="absolute inset-x-0 top-0 h-4 bg-pink-300/50"></div>
                </div>
                <!-- Tier 3 (Large) -->
                <div class="w-64 h-20 bg-pink-500 rounded-b-lg z-0 relative shadow-2xl shadow-pink-500/20">
                    <div class="absolute inset-x-0 top-0 h-4 bg-pink-400/50"></div>
                    <!-- Frosting Drip -->
                    <div class="absolute top-0 left-4 w-4 h-8 bg-white/30 rounded-b-full"></div>
                    <div class="absolute top-0 left-20 w-4 h-10 bg-white/30 rounded-b-full"></div>
                    <div class="absolute top-0 right-8 w-4 h-6 bg-white/30 rounded-b-full"></div>
                </div>
            </div>

            <h1 class="text-4xl font-script text-white mt-12 animate-bounce">Love u always! 💗💗</h1>
        </div>

    </div>

    <script>
        // Generate Floating Hearts
        const container = document.getElementById('hearts-container');
        for (let i = 0; i < 20; i++) {
            const heart = document.createElement('div');
            heart.className = 'heart';
            heart.innerHTML = '💘';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDelay = Math.random() * 5 + 's';
            heart.style.fontSize = (Math.random() * 20 + 10) + 'px';
            container.appendChild(heart);
        }

        // Navigation Logic
        function nextCard(currentId) {
            document.getElementById(`card-${currentId}`).style.display = 'none';
            document.getElementById(`card-${currentId + 1}`).style.display = 'block';
        }

        function showCake() {
            document.getElementById('card-3').style.display = 'none';
            document.getElementById('cake-screen').style.display = 'block';
            confettiEffect();
        }

        // Music Toggle
        function toggleMusic() {
            const music = document.getElementById('bgMusic');
            const icon = document.getElementById('musicIcon');
            if (music.paused) {
                music.play();
                icon.innerHTML = '⏸️';
            } else {
                music.pause();
                icon.innerHTML = '🎵';
            }
        }

        function confettiEffect() {
            for(let i=0; i<50; i++) {
                const s = document.createElement('div');
                s.className = 'sparkle';
                s.style.left = Math.random() * 100 + 'vw';
                s.style.top = Math.random() * 100 + 'vh';
                s.style.backgroundColor = `hsl(${Math.random() * 360}, 100%, 75%)`;
                document.body.appendChild(s);
            }
        }
    </script>
</body>
</html>
